# oly-ingestion/.env.example
# Copy this file to .env and fill in real values before running docker compose.
#
#   cp .env.example .env
#
# .env is gitignored — never commit real credentials.

# ── Postgres credentials ───────────────────────────────────────────────────
# Used by docker-compose to initialise Postgres and by PgBouncer to connect.
# Change POSTGRES_PASSWORD before starting containers for the first time.
POSTGRES_USER=oly
POSTGRES_PASSWORD=change_me_before_first_run
POSTGRES_DB=oly_programming

# ── Application database URL ───────────────────────────────────────────────
# Points at PgBouncer (port 5432). Must match POSTGRES_* credentials above.
DATABASE_URL=postgresql://oly:change_me_before_first_run@localhost:5432/oly_programming

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── API keys ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Web / session ─────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_random_64_char_hex_string

# ── Production overrides (uncomment when deploying) ───────────────────────
# LOG_FORMAT=json
# LOG_LEVEL=INFO
# HTTPS_ONLY=true
